# =================================================================
# SPRING SECURITY HUB - CONFIGURAÇÕES DE AMBIENTE
# Copie este arquivo para um novo chamado '.env' e preencha os dados
# =================================================================

# --- BANCO DE DADOS (MySQL) ---
DB_USERNAME=root
DB_PASSWORD=123
DB_URL=jdbc:mysql://mysql-db:3306/mydb

# --- GOOGLE OAUTH2 ---
# Obtenha em: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=seu_client_id_aqui.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret_aqui

# --- CONFIGURAÇÃO DE E-MAIL (Gmail SMTP) ---
# Necessário criar uma "Senha de App" na sua conta Google
GMAIL_USER=seu-email@gmail.com
GMAIL_APP_PASSWORD=sua_senha_de_app_aqui

# --- FRONTEND ---
# Se rodar via Docker, use localhost. Se for celular, use seu IP.
VITE_API_URL=http://localhost:8080